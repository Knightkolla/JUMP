# Copy this to .env and fill in your values.

# Required only for LLM selector-derivation fallback (POST /v1/derive-selector).
# Any OpenAI-compatible key works (OpenAI, Together, Groq, local Ollama with OpenAI adapter, etc.)
OPENAI_API_KEY=sk-...

# Override these to point at a different OpenAI-compatible endpoint or model.
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
